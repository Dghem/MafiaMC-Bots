{
  "name": "minecraft-afk-bot",
  "version": "2.2",
  "description": "Robust AFK bot for Minecraft servers with infinite uptime.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --check index.js",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path');const base='node_modules/minecraft-data/minecraft-data/data';const pc=path.join(base,'pc');const keepPc=['1.7','1.8','1.16.2','common'];if(fs.existsSync(pc))fs.readdirSync(pc).filter(v=>!keepPc.includes(v)).forEach(v=>fs.rmSync(path.join(pc,v),{recursive:true,force:true}));const bd=path.join(base,'bedrock');if(fs.existsSync(bd))fs.readdirSync(bd).filter(v=>v!=='common').forEach(v=>fs.rmSync(path.join(bd,v),{recursive:true,force:true}));console.log('[postinstall] minecraft-data pruned (kept 1.7/1.8/1.16.2/common).');\""
  },
  "author": "Lamgerr",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.1",
    "minecraft-data": "^3.103.0",
    "mineflayer": "^4.34.0",
    "mineflayer-pathfinder": "^2.1.1"
  }
}
